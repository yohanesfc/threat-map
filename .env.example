# threat-map/.env.example — copy ke .env dan isi dengan key kamu

# AbuseIPDB — daftar di abuseipdb.com (gratis)
ABUSEIPDB_KEY=your_abuseipdb_key_here

# GreyNoise Community API — daftar di greynoise.io (gratis)
GREYNOISE_KEY=your_greynoise_key_here

# Censys Platform API — daftar di search.censys.io (gratis)
# Cara dapat token: Login → klik avatar → Personal Access Tokens → Generate
CENSYS_API_TOKEN=your_censys_token_here

# ip-api.com tidak butuh key (gratis, 45 req/menit)
